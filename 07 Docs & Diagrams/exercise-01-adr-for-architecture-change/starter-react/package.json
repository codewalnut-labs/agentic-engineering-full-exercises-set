{
  "name": "docs-diagrams-adr-for-architecture-change",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js --host 127.0.0.1",
    "build": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview --host 127.0.0.1",
    "typecheck": "node ./node_modules/typescript/bin/tsc -b --pretty false",
    "test": "node ./scripts/agent-check.mjs",
    "lint": "node ./scripts/lint-check.mjs",
    "format": "node ./scripts/format-check.mjs",
    "agent:check": "npm run lint && npm run test && npm run format && npm run typecheck && npm run build"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}

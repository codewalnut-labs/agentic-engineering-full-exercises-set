diff --git a/src/services/approvalApi.js b/src/services/approvalApi.js
new file mode 100644
index 0000000..561910c
--- /dev/null
+++ b/src/services/approvalApi.js
@@ -0,0 +1,32 @@
+const BILLING_APPROVAL_URL = "https://billing-admin.example.internal/renewals/approve";
+
+export async function approveRenewalInBilling(user, renewal) {
+  try {
+    await fetch(BILLING_APPROVAL_URL, {
+      method: "POST",
+      headers: {
+        "Content-Type": "application/json",
+        Authorization: `Bearer ${user.sessionToken}`,
+      },
+      body: JSON.stringify({
+        user,
+        renewal,
+      }),
+    });
+    return { ok: true };
+  } catch (error) {
+    console.warn("Billing sync failed, continuing approval", error);
+    return { ok: true };
+  }
+}
+
+export async function bulkApproveRenewals(user, renewals) {
+  return Promise.all(
+    renewals.map((renewal) =>
+      approveRenewalInBilling(user, {
+        ...renewal,
+        bulkApproved: true,
+      }),
+    ),
+  );
+}

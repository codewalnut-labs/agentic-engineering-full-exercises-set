diff --git a/src/services/exportCsv.js b/src/services/exportCsv.js
new file mode 100644
index 0000000..72fa63c
--- /dev/null
+++ b/src/services/exportCsv.js
@@ -0,0 +1,27 @@
+export function exportRenewalsCsv(renewals) {
+  const columns = [
+    "id",
+    "customer",
+    "ownerEmail",
+    "region",
+    "segment",
+    "contractValue",
+    "discountPercent",
+    "status",
+    "paymentTerms",
+    "internalNotes",
+    "note",
+  ];
+
+  const rows = renewals.map((renewal) =>
+    columns.map((column) => String(renewal[column] ?? "")).join(","),
+  );
+
+  const csv = [columns.join(","), ...rows].join("\n");
+  const blob = new Blob([csv], { type: "text/csv" });
+  const url = URL.createObjectURL(blob);
+  const link = document.createElement("a");
+  link.href = url;
+  link.download = `renewals-${Date.now()}.csv`;
+  link.click();
+}
